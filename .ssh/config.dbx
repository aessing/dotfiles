# EMU GitHub account (explicit alias for managed orgs)
Host github.com-emu
  HostName github.com
  User git
  IdentityFile ~/.ssh/github_emu_key
  IdentitiesOnly yes
  AddKeysToAgent yes
  UseKeychain yes

# Personal GitHub account (default for everything else)
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/github_personal_key
  IdentitiesOnly yes
  AddKeysToAgent yes
  UseKeychain yes